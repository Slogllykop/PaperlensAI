# ==========================================
# PaperLens AI - Environment Variables Guide
# ==========================================

# ------------------------------------------
# 1. Supabase Database Configuration
# ------------------------------------------
# Find these in your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# ------------------------------------------
# 2. Upstash Redis Configuration (Caching & Status)
# ------------------------------------------
# Find these in the Upstash Console -> Redis -> Your Database
UPSTASH_REDIS_REST_URL="https://your-upstash-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ------------------------------------------
# 3. Upstash QStash Configuration (Background Jobs)
# ------------------------------------------
# Find these in the Upstash Console -> QStash
# Required for async paper analysis via webhook delivery.
# Note: QStash CANNOT reach localhost directly. When running locally without APP_URL, 
# analysis runs synchronously in-process (QStash is bypassed).
QSTASH_URL="https://qstash.upstash.io/v2/messages"
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-qstash-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-qstash-next-signing-key"

# ------------------------------------------
# 4. Application Configuration
# ------------------------------------------
# Set this to your deployed URL so QStash can deliver webhooks.
# Example: https://paperlens.vercel.app
# To test QStash locally, use ngrok (e.g., https://<id>.ngrok-free.app)
APP_URL="https://in-paperlensai.vercel.app"

# ------------------------------------------
# 5. Groq AI Configuration (LLM Inference)
# ------------------------------------------
# Generate an API key from console.groq.com
GROQ_API_KEY="gsk_your_api_key_here"